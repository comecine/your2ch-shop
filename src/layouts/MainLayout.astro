---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = '绿巢生活館', description = '绿巢生活館 - 自然生活，从家开始' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <title>{title} - 绿巢生活館</title>
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

  <!-- Toast 容器 -->
  <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

  <!-- Header -->
  <header class="bg-white shadow-sm sticky top-0 z-40">
    <!-- 顶部品牌栏 -->
    <div class="bg-primary text-white py-1.5 px-4 text-xs text-center hidden sm:block">
      欢迎来到绿巢生活館！自然好物，呵护每个家庭 🌿 满99元包邮
    </div>

    <!-- 主导航 -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-white fill-current">
              <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 2-8 2 2-2 2-4 2-4-5 0-9 4-9 10a9.09 9.09 0 00.1 1.42C2.82 14.49 3 12 3 12 2 17 3.5 19 3.5 19" />
            </svg>
          </div>
          <div>
            <div class="text-lg font-bold text-primary leading-tight">绿巢生活館</div>
            <div class="text-xs text-gray-400 leading-tight hidden sm:block">自然生活 从家开始</div>
          </div>
        </a>

        <!-- 搜索栏（PC） -->
        <div class="hidden md:flex flex-1 max-w-xl mx-8">
          <div class="relative w-full">
            <input
              type="text"
              id="search-input"
              placeholder="搜索商品，例如：洗碗布、竹纤维..."
              class="w-full pl-4 pr-12 py-2.5 border-2 border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-light text-sm"
            />
            <button
              id="search-btn"
              class="absolute right-0 top-0 h-full px-4 bg-primary text-white rounded-r-lg hover:bg-primary-dark transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
              </svg>
            </button>
          </div>
        </div>

        <!-- 右侧功能区 -->
        <div class="flex items-center gap-3">
          <!-- 购物车 -->
          <a href="/cart" class="relative p-2 text-gray-600 hover:text-primary transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span id="cart-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center hidden">0</span>
          </a>

          <!-- 用户区 -->
          <div id="auth-nav" class="flex items-center gap-2">
            <a href="/account/login" class="text-sm text-gray-600 hover:text-primary transition-colors hidden sm:block">登录</a>
            <a href="/account/register" class="btn-primary btn-sm hidden sm:inline-flex">注册</a>
          </div>
        </div>
      </div>

      <!-- 导航菜单 -->
      <nav class="border-t border-gray-100">
        <ul class="flex items-center gap-0 overflow-x-auto">
          <li>
            <a href="/" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:text-primary hover:bg-primary-light transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-primary">
              首页
            </a>
          </li>
          <li>
            <a href="/products" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:text-primary hover:bg-primary-light transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-primary">
              全部商品
            </a>
          </li>
          <!-- 动态分类（JS载入） -->
          <li id="categories-nav" class="flex items-center">
            <!-- 由 JS 动态插入 -->
          </li>
        </ul>
      </nav>

      <!-- 移动端搜索 -->
      <div class="md:hidden pb-3">
        <div class="relative">
          <input
            type="text"
            id="search-input-mobile"
            placeholder="搜索商品..."
            class="w-full pl-4 pr-12 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-sm"
          />
          <button
            id="search-btn-mobile"
            class="absolute right-0 top-0 h-full px-4 bg-primary text-white rounded-r-lg"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- 主体内容 -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-800 text-gray-300 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- 品牌介绍 -->
        <div class="md:col-span-1">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-4 h-4 text-white fill-current">
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 2-8 2 2-2 2-4 2-4-5 0-9 4-9 10a9.09 9.09 0 00.1 1.42C2.82 14.49 3 12 3 12 2 17 3.5 19 3.5 19" />
              </svg>
            </div>
            <span class="text-white font-bold">绿巢生活館</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            专注于自然、环保的家居生活用品，为每个家庭提供高品质、亲自然的生活好物。
          </p>
        </div>

        <!-- 快速导航 -->
        <div>
          <h4 class="text-white font-medium mb-4">快速导航</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="hover:text-primary transition-colors">首页</a></li>
            <li><a href="/products" class="hover:text-primary transition-colors">全部商品</a></li>
            <li><a href="/cart" class="hover:text-primary transition-colors">购物车</a></li>
            <li><a href="/account/orders" class="hover:text-primary transition-colors">我的订单</a></li>
          </ul>
        </div>

        <!-- 帮助中心 -->
        <div>
          <h4 class="text-white font-medium mb-4">帮助中心</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/account/login" class="hover:text-primary transition-colors">登录/注册</a></li>
            <li><span class="text-gray-500">配送说明（满99包邮）</span></li>
            <li><span class="text-gray-500">退换货政策</span></li>
            <li><span class="text-gray-500">隐私政策</span></li>
          </ul>
        </div>

        <!-- 联系我们 -->
        <div>
          <h4 class="text-white font-medium mb-4">联系我们</h4>
          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:service@your2ch.com" class="hover:text-primary transition-colors">service@your2ch.com</a>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-gray-400">客服时间：9:00-18:00</span>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-700 mt-8 pt-6 text-center text-xs text-gray-500 space-y-1">
        <p>© 2026 绿巢生活館 版权所有 | 主办单位：江西远南贸易有限公司</p>
        <p>
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
            赣ICP备2025058819号
          </a>
        </p>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  // 从 localStorage 更新购物车数量
  function updateCartBadge() {
    const cartCount = parseInt(localStorage.getItem('cartCount') || '0');
    const badge = document.getElementById('cart-badge');
    if (badge) {
      if (cartCount > 0) {
        badge.textContent = cartCount > 99 ? '99+' : String(cartCount);
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
  }

  // 检查登录状态
  async function checkAuthStatus() {
    try {
      const res = await fetch('/api/auth/me', { credentials: 'include' });
      const authNav = document.getElementById('auth-nav');
      if (!authNav) return;

      if (res.ok) {
        const data = await res.json();
        const user = data.user || data;
        authNav.innerHTML = `
          <div class="relative group">
            <button class="flex items-center gap-1.5 text-sm text-gray-700 hover:text-primary transition-colors">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span class="hidden sm:inline">${user.username || '我的账户'}</span>
              <svg class="w-3 h-3 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute right-0 mt-1 w-40 bg-white rounded-lg shadow-lg border border-gray-100 py-1 hidden group-hover:block z-50">
              <a href="/account/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-light hover:text-primary">个人资料</a>
              <a href="/account/orders" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-light hover:text-primary">我的订单</a>
              <a href="/account/addresses" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-light hover:text-primary">收货地址</a>
              <hr class="my-1 border-gray-100" />
              <button id="logout-btn" class="block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50">退出登录</button>
            </div>
          </div>
        `;

        document.getElementById('logout-btn')?.addEventListener('click', async () => {
          await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
          localStorage.removeItem('cartCount');
          window.location.href = '/';
        });
      }
    } catch (e) {
      // 未登录，保持默认状态
    }
  }

  // 加载分类到导航
  async function loadCategories() {
    try {
      const res = await fetch('/api/categories', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const categories = data.categories || data || [];
      const nav = document.getElementById('categories-nav');
      if (!nav || categories.length === 0) return;

      categories.slice(0, 6).forEach((cat: any) => {
        const li = document.createElement('li');
        li.innerHTML = `
          <a href="/products?category=${cat.slug}" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:text-primary hover:bg-primary-light transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-primary">
            ${cat.icon ? cat.icon + ' ' : ''}${cat.name}
          </a>
        `;
        nav.appendChild(li);
      });
    } catch (e) {
      // 分类加载失败不影响页面
    }
  }

  // 搜索功能
  function setupSearch() {
    const doSearch = (inputId: string) => {
      const input = document.getElementById(inputId) as HTMLInputElement;
      if (input && input.value.trim()) {
        window.location.href = `/products?q=${encodeURIComponent(input.value.trim())}`;
      }
    };

    document.getElementById('search-btn')?.addEventListener('click', () => doSearch('search-input'));
    document.getElementById('search-btn-mobile')?.addEventListener('click', () => doSearch('search-input-mobile'));

    ['search-input', 'search-input-mobile'].forEach(id => {
      document.getElementById(id)?.addEventListener('keydown', (e: Event) => {
        if ((e as KeyboardEvent).key === 'Enter') doSearch(id);
      });
    });
  }

  // 初始化
  updateCartBadge();
  checkAuthStatus();
  loadCategories();
  setupSearch();

  // 监听 localStorage 变化（其他标签页更新购物车）
  window.addEventListener('storage', (e) => {
    if (e.key === 'cartCount') updateCartBadge();
  });
</script>
