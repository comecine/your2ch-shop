---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="配送说明">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">配送说明</h1>
    <p class="text-sm text-gray-400 mb-8">最后更新：2026年1月</p>

    <!-- 包邮政策 -->
    <section class="mb-8 p-6 bg-green-50 rounded-xl border border-green-100">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">🚚</span>
        <h2 class="text-lg font-bold text-green-700">满99元免运费</h2>
      </div>
      <p class="text-gray-700 text-sm leading-relaxed">
        单笔订单实付金额满 <strong>¥99</strong> 即可享受全场免运费配送。未满¥99的订单，运费为 <strong>¥10</strong>（偏远地区另计）。
      </p>
    </section>

    <!-- 运费说明 -->
    <section class="mb-8">
      <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-5 bg-primary rounded-full inline-block"></span>
        运费标准
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="text-left px-4 py-3 font-medium text-gray-700 rounded-tl-lg">地区</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700">首重（1kg）</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700">续重（每kg）</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700 rounded-tr-lg">包邮门槛</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-700">华东、华南、华北</td>
              <td class="px-4 py-3 text-gray-600">¥10</td>
              <td class="px-4 py-3 text-gray-600">¥2</td>
              <td class="px-4 py-3 text-green-600 font-medium">满¥99免运费</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-700">华中、西南、西北</td>
              <td class="px-4 py-3 text-gray-600">¥12</td>
              <td class="px-4 py-3 text-gray-600">¥3</td>
              <td class="px-4 py-3 text-green-600 font-medium">满¥99免运费</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-700">东北地区</td>
              <td class="px-4 py-3 text-gray-600">¥12</td>
              <td class="px-4 py-3 text-gray-600">¥3</td>
              <td class="px-4 py-3 text-green-600 font-medium">满¥99免运费</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-700">新疆、西藏、内蒙古</td>
              <td class="px-4 py-3 text-gray-600">¥25</td>
              <td class="px-4 py-3 text-gray-600">¥5</td>
              <td class="px-4 py-3 text-gray-500">暂不参与包邮</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 配送时效 -->
    <section class="mb-8">
      <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-5 bg-primary rounded-full inline-block"></span>
        配送时效
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="p-4 bg-gray-50 rounded-xl text-center">
          <div class="text-2xl mb-2">📦</div>
          <div class="font-bold text-gray-800 mb-1">下单后1天</div>
          <div class="text-xs text-gray-500">完成备货打包</div>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl text-center">
          <div class="text-2xl mb-2">🚚</div>
          <div class="font-bold text-gray-800 mb-1">3～5个工作日</div>
          <div class="text-xs text-gray-500">快递送达（普通地区）</div>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl text-center">
          <div class="text-2xl mb-2">📱</div>
          <div class="font-bold text-gray-800 mb-1">全程可追踪</div>
          <div class="text-xs text-gray-500">短信通知 + 物流查询</div>
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-3">※ 节假日、台风、雪灾等特殊情况可能造成延误，请以实际物流信息为准。</p>
    </section>

    <!-- 注意事项 -->
    <section class="mb-8">
      <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-5 bg-primary rounded-full inline-block"></span>
        注意事项
      </h2>
      <ul class="space-y-3 text-sm text-gray-600">
        <li class="flex items-start gap-2">
          <span class="text-primary mt-0.5">•</span>
          <span>每日 <strong>14:00</strong> 前付款的订单，当天安排发货；14:00 后付款的订单，次日安排发货。</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary mt-0.5">•</span>
          <span>如遇库存不足，客服会在24小时内联系您协商处理方案（补货、换货或退款）。</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary mt-0.5">•</span>
          <span>收货时请当面验货，如发现包装破损、商品缺失，请拒绝签收并联系客服。</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary mt-0.5">•</span>
          <span>合并订单或拆分发货的情况，以实际发货快递单号为准。</span>
        </li>
      </ul>
    </section>

    <!-- 联系客服 -->
    <div class="p-4 bg-primary-light rounded-xl text-center">
      <p class="text-sm text-gray-700">有配送相关疑问？欢迎联系我们</p>
      <a href="mailto:service@your2ch.com" class="text-primary font-medium text-sm hover:underline">service@your2ch.com</a>
      <span class="text-gray-400 text-xs ml-2">客服时间：周一至周日 9:00–18:00</span>
    </div>
  </div>
</MainLayout>
