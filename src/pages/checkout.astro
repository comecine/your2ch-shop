---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="确认订单">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">确认订单</h1>

    <!-- 加载 -->
    <div id="checkout-loading" class="flex justify-center py-16">
      <svg class="w-8 h-8 animate-spin text-primary" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
      </svg>
    </div>

    <div id="checkout-content" class="hidden">
      <!-- 步骤指示 -->
      <div class="flex items-center justify-center mb-8 gap-0">
        <div class="flex items-center">
          <div class="w-7 h-7 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold">1</div>
          <div class="text-sm text-primary font-medium ml-2">购物车</div>
        </div>
        <div class="w-12 h-0.5 bg-primary mx-3"></div>
        <div class="flex items-center">
          <div class="w-7 h-7 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold">2</div>
          <div class="text-sm text-primary font-medium ml-2">确认订单</div>
        </div>
        <div class="w-12 h-0.5 bg-gray-200 mx-3"></div>
        <div class="flex items-center">
          <div class="w-7 h-7 bg-gray-200 text-gray-400 rounded-full flex items-center justify-center text-sm font-bold">3</div>
          <div class="text-sm text-gray-400 ml-2">支付</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-5">
          <!-- 收货地址 -->
          <div class="card p-5">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-semibold text-gray-800">收货地址</h2>
              <button id="add-address-btn" class="text-sm text-primary hover:text-primary-dark transition-colors">+ 新增地址</button>
            </div>

            <div id="address-list" class="space-y-3 mb-3">
              <div class="animate-pulse space-y-2">
                <div class="h-16 bg-gray-100 rounded-lg"></div>
                <div class="h-16 bg-gray-100 rounded-lg"></div>
              </div>
            </div>

            <!-- 新增地址表单（折叠） -->
            <div id="add-address-form" class="hidden border border-dashed border-gray-300 rounded-xl p-4 mt-3">
              <h4 class="text-sm font-medium text-gray-700 mb-3">新增收货地址</h4>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-gray-500 mb-1">收货人</label>
                  <input type="text" id="new-name" class="input-field text-sm py-2" placeholder="姓名" />
                </div>
                <div>
                  <label class="block text-xs text-gray-500 mb-1">手机号</label>
                  <input type="tel" id="new-phone" class="input-field text-sm py-2" placeholder="手机号" />
                </div>
                <div class="col-span-2">
                  <label class="block text-xs text-gray-500 mb-1">详细地址</label>
                  <input type="text" id="new-detail" class="input-field text-sm py-2" placeholder="省市区 + 详细街道" />
                </div>
              </div>
              <div class="flex gap-2 mt-3">
                <button id="save-address-btn" class="btn-primary btn-sm">保存</button>
                <button id="cancel-address-btn" class="btn-outline btn-sm">取消</button>
              </div>
            </div>
          </div>

          <!-- 商品清单 -->
          <div class="card p-5">
            <h2 class="font-semibold text-gray-800 mb-4">商品清单</h2>
            <div id="order-items" class="space-y-3"></div>
          </div>

          <!-- 支付方式 -->
          <div class="card p-5">
            <h2 class="font-semibold text-gray-800 mb-4">支付方式</h2>
            <div class="border-2 border-primary rounded-xl p-4 bg-primary-light">
              <div class="flex items-center gap-3 mb-3">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
                <span class="font-medium text-primary">银行转账</span>
                <span class="badge badge-green">推荐</span>
              </div>
              <div class="text-sm text-gray-600 space-y-1.5 pl-9">
                <div>开户行：中国工商银行</div>
                <div>账户名：江西远南贸易有限公司</div>
                <div>账号：<span class="font-mono font-medium text-gray-800">1234 5678 9012 3456</span></div>
                <div class="text-xs text-gray-400 mt-2">提交订单后，请将转账凭证发至客服邮箱 service@your2ch.com，核实后即安排发货</div>
              </div>
            </div>
          </div>

          <!-- 备注 -->
          <div class="card p-5">
            <h2 class="font-semibold text-gray-800 mb-3">订单备注</h2>
            <textarea id="order-remark" class="input-field text-sm" rows="2" placeholder="如有特殊要求，请在此留言（选填）"></textarea>
          </div>
        </div>

        <!-- 右侧：订单摘要 -->
        <div>
          <div class="card p-5 sticky top-24">
            <h3 class="font-semibold text-gray-800 mb-4 pb-3 border-b border-gray-100">订单金额</h3>
            <div class="space-y-3 mb-4">
              <div class="flex justify-between text-sm text-gray-600">
                <span>商品总额</span>
                <span>¥<span id="items-total">0.00</span></span>
              </div>
              <div class="flex justify-between text-sm text-gray-600">
                <span>运费</span>
                <span id="shipping-fee-text" class="text-primary">免运费</span>
              </div>
            </div>
            <div class="flex justify-between font-bold text-lg pt-3 border-t border-gray-100 mb-5">
              <span>实付金额</span>
              <span class="text-red-500">¥<span id="final-total">0.00</span></span>
            </div>
            <button id="submit-order-btn" class="w-full btn-primary py-3 text-base" disabled>
              提交订单
            </button>
            <div class="mt-3 text-xs text-gray-400 text-center">
              提交订单后请按照银行转账信息付款
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  let selectedAddressId: number | null = null;
  let cartData: any[] = [];
  let addresses: any[] = [];

  async function init() {
    try {
      // 检查登录
      const authRes = await fetch('/api/auth/me', { credentials: 'include' });
      if (!authRes.ok) { window.location.href = '/account/login?redirect=/checkout'; return; }

      // 并行加载地址和购物车
      const [addrRes, cartRes] = await Promise.all([
        fetch('/api/addresses', { credentials: 'include' }),
        fetch('/api/cart', { credentials: 'include' })
      ]);

      addresses = addrRes.ok ? (await addrRes.json()).addresses || await addrRes.json() || [] : [];
      const cartRaw = cartRes.ok ? await cartRes.json() : { items: [] };
      const allItems = cartRaw.items || cartRaw || [];

      // 过滤选中的商品
      const selectedIds = JSON.parse(sessionStorage.getItem('checkout_items') || '[]');
      cartData = selectedIds.length > 0 ? allItems.filter((i: any) => selectedIds.includes(i.id)) : allItems;

      if (!cartData.length) { window.location.href = '/cart'; return; }

      document.getElementById('checkout-loading')!.classList.add('hidden');
      document.getElementById('checkout-content')!.classList.remove('hidden');

      renderAddresses();
      renderOrderItems();
      calculateTotal();
    } catch (e) {
      window.location.href = '/cart';
    }
  }

  function renderAddresses() {
    const container = document.getElementById('address-list')!;
    if (!addresses.length) {
      container.innerHTML = '<div class="text-sm text-gray-400 text-center py-4">暂无收货地址，请添加</div>';
      return;
    }

    container.innerHTML = addresses.map(addr => `
      <div
        class="address-item border-2 rounded-xl p-4 cursor-pointer transition-all ${addr.is_default || addresses.length === 1 ? 'border-primary bg-primary-light' : 'border-gray-200 hover:border-gray-300'}"
        data-id="${addr.id}"
      >
        <div class="flex items-start justify-between">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="font-medium text-gray-800">${addr.name}</span>
              <span class="text-gray-600 text-sm">${addr.phone}</span>
              ${addr.is_default ? '<span class="badge badge-green">默认</span>' : ''}
            </div>
            <div class="text-sm text-gray-600">${addr.province}${addr.city}${addr.district} ${addr.detail}</div>
          </div>
          <div class="w-5 h-5 rounded-full border-2 border-primary flex items-center justify-center flex-shrink-0 mt-1">
            <div class="w-2.5 h-2.5 rounded-full bg-primary ${addr.is_default || addresses.length === 1 ? '' : 'hidden'}"></div>
          </div>
        </div>
      </div>
    `).join('');

    // 默认选中
    const defaultAddr = addresses.find(a => a.is_default) || addresses[0];
    if (defaultAddr) selectedAddressId = defaultAddr.id;
    checkSubmitReady();

    // 点击选择地址
    document.querySelectorAll('.address-item').forEach(item => {
      item.addEventListener('click', () => {
        selectedAddressId = parseInt((item as HTMLElement).dataset.id || '0');
        document.querySelectorAll('.address-item').forEach(i => {
          i.classList.remove('border-primary', 'bg-primary-light');
          i.classList.add('border-gray-200');
          i.querySelector('.w-2\\.5')?.classList.add('hidden');
        });
        item.classList.add('border-primary', 'bg-primary-light');
        item.classList.remove('border-gray-200');
        item.querySelector('.w-2\\.5')?.classList.remove('hidden');
        checkSubmitReady();
      });
    });
  }

  function renderOrderItems() {
    const container = document.getElementById('order-items')!;
    container.innerHTML = cartData.map(item => `
      <div class="flex items-center gap-3">
        <img src="${item.product_image || 'https://placehold.co/60x60/dcfce7/16a34a?text=图片'}"
          alt="${item.product_name}"
          class="w-14 h-14 rounded-lg object-cover flex-shrink-0"
          onerror="this.src='https://placehold.co/60x60/dcfce7/16a34a?text=图片'"
        />
        <div class="flex-1 min-w-0">
          <div class="text-sm text-gray-800 line-clamp-1">${item.product_name}</div>
          <div class="text-xs text-gray-400">x${item.quantity}</div>
        </div>
        <div class="text-sm font-bold text-gray-800 flex-shrink-0">
          ¥${(parseFloat(String(item.price)) * item.quantity).toFixed(2)}
        </div>
      </div>
    `).join('');
  }

  function calculateTotal() {
    const subtotal = cartData.reduce((sum, item) => sum + parseFloat(String(item.price)) * item.quantity, 0);
    const shipping = subtotal >= 99 ? 0 : 10;
    const total = subtotal + shipping;

    document.getElementById('items-total')!.textContent = subtotal.toFixed(2);
    document.getElementById('final-total')!.textContent = total.toFixed(2);

    const shipEl = document.getElementById('shipping-fee-text')!;
    if (shipping === 0) {
      shipEl.textContent = '免运费';
      shipEl.className = 'text-primary font-medium';
    } else {
      shipEl.textContent = `¥${shipping.toFixed(2)}`;
      shipEl.className = 'text-gray-700';
    }
  }

  function checkSubmitReady() {
    const btn = document.getElementById('submit-order-btn') as HTMLButtonElement;
    btn.disabled = !selectedAddressId;
  }

  // 新增地址
  document.getElementById('add-address-btn')?.addEventListener('click', () => {
    document.getElementById('add-address-form')!.classList.toggle('hidden');
  });

  document.getElementById('cancel-address-btn')?.addEventListener('click', () => {
    document.getElementById('add-address-form')!.classList.add('hidden');
  });

  document.getElementById('save-address-btn')?.addEventListener('click', async () => {
    const name = (document.getElementById('new-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('new-phone') as HTMLInputElement).value.trim();
    const detail = (document.getElementById('new-detail') as HTMLInputElement).value.trim();

    if (!name || !phone || !detail) { alert('请填写完整地址信息'); return; }

    try {
      const res = await fetch('/api/addresses', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone, province: '', city: '', district: '', detail, is_default: addresses.length === 0 })
      });
      if (res.ok) {
        const data = await res.json();
        addresses.push(data.address || data);
        document.getElementById('add-address-form')!.classList.add('hidden');
        renderAddresses();
      }
    } catch (e) {}
  });

  // 提交订单
  document.getElementById('submit-order-btn')?.addEventListener('click', async () => {
    if (!selectedAddressId) return;
    const btn = document.getElementById('submit-order-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '提交中...';

    try {
      const remark = (document.getElementById('order-remark') as HTMLTextAreaElement).value.trim();
      const res = await fetch('/api/orders', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          address_id: selectedAddressId,
          cart_item_ids: cartData.map(i => i.id),
          payment_method: 'bank_transfer',
          remark
        })
      });

      if (res.ok) {
        const data = await res.json();
        sessionStorage.removeItem('checkout_items');
        localStorage.removeItem('cartCount');
        window.location.href = `/account/orders/${data.order_id || data.id}?success=1`;
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.message || '提交失败，请重试');
        btn.disabled = false;
        btn.textContent = '提交订单';
      }
    } catch (e) {
      alert('网络错误，请重试');
      btn.disabled = false;
      btn.textContent = '提交订单';
    }
  });

  init();
</script>
