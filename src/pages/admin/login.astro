---
import '../../styles/global.css';
// 后台登录页，不使用 AdminLayout
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>管理员登录 - 绿巢生活館</title>
  <style>
    body { background: linear-gradient(135deg, #1a2f1f 0%, #0f1f13 100%); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg viewBox="0 0 24 24" class="w-9 h-9 text-white fill-current">
          <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 2-8 2 2-2 2-4 2-4-5 0-9 4-9 10a9.09 9.09 0 00.1 1.42C2.82 14.49 3 12 3 12 2 17 3.5 19 3.5 19" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">绿巢生活館</h1>
      <p class="text-gray-400 text-sm mt-1">管理后台</p>
    </div>

    <div class="bg-gray-800 rounded-2xl p-8 shadow-xl border border-gray-700">
      <h2 class="text-lg font-semibold text-white mb-6 text-center">管理员登录</h2>

      <div id="error-msg" class="hidden mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-sm text-red-300"></div>

      <form id="admin-login-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5">用户名</label>
          <input
            type="text"
            id="admin-username"
            class="w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent placeholder-gray-500"
            placeholder="请输入管理员用户名"
            required
            autocomplete="username"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5">密码</label>
          <div class="relative">
            <input
              type="password"
              id="admin-password"
              class="w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent placeholder-gray-500 pr-10"
              placeholder="请输入密码"
              required
              autocomplete="current-password"
            />
            <button type="button" id="toggle-pwd" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-200">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>

        <button
          type="submit"
          id="login-btn"
          class="w-full bg-primary hover:bg-primary-dark text-white font-medium py-3 rounded-lg transition-colors"
        >
          登录
        </button>
      </form>

      <div class="mt-6 text-center">
        <a href="/" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">← 返回前台首页</a>
      </div>
    </div>

    <div class="text-center mt-6 text-xs text-gray-600">
      © 2026 绿巢生活館 管理后台
    </div>
  </div>
</body>
</html>

<script>
  // 如果已登录，跳转到后台
  if (document.cookie.includes('admin_token=')) {
    window.location.href = '/admin/';
  }

  document.getElementById('toggle-pwd')?.addEventListener('click', () => {
    const input = document.getElementById('admin-password') as HTMLInputElement;
    input.type = input.type === 'password' ? 'text' : 'password';
  });

  document.getElementById('admin-login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('admin-username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('admin-password') as HTMLInputElement).value;
    const errorEl = document.getElementById('error-msg')!;
    const btn = document.getElementById('login-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = '登录中...';

    try {
      const res = await fetch('/api/admin/auth/login', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });

      const data = await res.json();

      if (res.ok) {
        window.location.href = '/admin/';
      } else {
        errorEl.textContent = data.message || '账号或密码错误';
        errorEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = '登录';
      }
    } catch (err) {
      errorEl.textContent = '网络错误，请重试';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = '登录';
    }
  });
</script>
