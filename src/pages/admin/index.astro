---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="仪表盘">
  <!-- 统计卡 -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
    <div class="admin-stat-card">
      <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">📋</div>
      <div>
        <div class="text-2xl font-bold text-gray-900" id="stat-orders">-</div>
        <div class="text-sm text-gray-500">总订单</div>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">👥</div>
      <div>
        <div class="text-2xl font-bold text-gray-900" id="stat-users">-</div>
        <div class="text-sm text-gray-500">总会员</div>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">📦</div>
      <div>
        <div class="text-2xl font-bold text-gray-900" id="stat-products">-</div>
        <div class="text-sm text-gray-500">商品数</div>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">💰</div>
      <div>
        <div class="text-2xl font-bold text-gray-900" id="stat-revenue">-</div>
        <div class="text-sm text-gray-500">本月销售额</div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- 最近订单 -->
    <div class="lg:col-span-2 card p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-gray-800">最近订单</h2>
        <a href="/admin/orders/" class="text-sm text-primary hover:text-primary-dark">查看全部</a>
      </div>
      <div class="overflow-x-auto">
        <table class="table-default">
          <thead>
            <tr>
              <th>订单号</th>
              <th>用户</th>
              <th>金额</th>
              <th>状态</th>
              <th>时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="recent-orders">
            <tr><td colspan="6" class="text-center text-gray-400 py-8">加载中...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 低库存警示 -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-gray-800">低库存警示</h2>
        <a href="/admin/inventory/" class="text-sm text-primary hover:text-primary-dark">管理库存</a>
      </div>
      <div id="low-stock-list" class="space-y-3">
        <div class="animate-pulse space-y-3">
          {Array(3).fill(0).map(() => (
            <div class="h-12 bg-gray-100 rounded-lg"></div>
          ))}
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const statusMap: Record<string, string> = {
    pending: '待确认',
    confirmed: '已确认',
    shipped: '已发货',
    completed: '已完成',
    cancelled: '已取消',
  };

  const statusClass: Record<string, string> = {
    pending: 'badge-yellow',
    confirmed: 'badge-blue',
    shipped: 'badge-green',
    completed: 'badge bg-gray-100 text-gray-600',
    cancelled: 'badge-red',
  };

  async function loadStats() {
    try {
      const res = await fetch('/api/admin/stats', { credentials: 'include' });
      if (res.status === 401) { window.location.href = '/admin/login'; return; }
      if (!res.ok) return;
      const data = await res.json();

      document.getElementById('stat-orders')!.textContent = String(data.total_orders || 0);
      document.getElementById('stat-users')!.textContent = String(data.total_users || 0);
      document.getElementById('stat-products')!.textContent = String(data.total_products || 0);
      document.getElementById('stat-revenue')!.textContent = `¥${parseFloat(data.month_revenue || 0).toFixed(0)}`;

      // 最近订单
      const orders = data.recent_orders || [];
      const tbody = document.getElementById('recent-orders')!;
      tbody.innerHTML = orders.length ? orders.slice(0, 5).map((o: any) => `
        <tr>
          <td class="font-mono text-xs">${o.order_no || o.id}</td>
          <td>${o.username || o.user_id}</td>
          <td class="font-bold text-gray-900">¥${parseFloat(o.total_amount).toFixed(2)}</td>
          <td><span class="${statusClass[o.status] || 'badge-gray'}">${statusMap[o.status] || o.status}</span></td>
          <td class="text-xs text-gray-400">${new Date(o.created_at).toLocaleDateString('zh-CN')}</td>
          <td><a href="/admin/orders/${o.id}" class="text-primary text-xs hover:underline">查看</a></td>
        </tr>
      `).join('') : '<tr><td colspan="6" class="text-center text-gray-400 py-8">暂无订单</td></tr>';

      // 低库存
      const lowStock = data.low_stock || [];
      const lowStockEl = document.getElementById('low-stock-list')!;
      lowStockEl.innerHTML = lowStock.length ? lowStock.slice(0, 8).map((p: any) => `
        <div class="flex items-center gap-3 p-2.5 rounded-lg ${p.stock === 0 ? 'bg-red-50' : 'bg-orange-50'}">
          <img src="${p.main_image || 'https://placehold.co/40x40/dcfce7/16a34a?text=图'}"
            class="w-10 h-10 rounded-lg object-cover flex-shrink-0"
            onerror="this.src='https://placehold.co/40x40/dcfce7/16a34a?text=图'"
          />
          <div class="flex-1 min-w-0">
            <div class="text-xs font-medium text-gray-800 line-clamp-1">${p.name}</div>
            <div class="text-xs ${p.stock === 0 ? 'text-red-600 font-bold' : 'text-orange-600'}">库存：${p.stock}</div>
          </div>
          <a href="/admin/inventory/" class="text-xs text-primary flex-shrink-0">补货</a>
        </div>
      `).join('') : '<div class="text-center py-6 text-sm text-gray-400">所有商品库存充足</div>';
    } catch (e) {
      console.error('Failed to load stats:', e);
    }
  }

  loadStats();
</script>
