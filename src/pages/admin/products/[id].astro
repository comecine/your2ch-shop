---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const { id } = Astro.params;
---

<AdminLayout title="编辑商品">
  <div class="max-w-3xl">
    <div class="flex items-center gap-3 mb-5">
      <a href="/admin/products/" class="text-gray-400 hover:text-gray-600 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h2 class="text-lg font-semibold text-gray-800">编辑商品</h2>
    </div>

    <div id="loading" class="flex justify-center py-12">
      <svg class="w-8 h-8 animate-spin text-primary" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
      </svg>
    </div>

    <div id="form-container" class="hidden">
      <div id="error-msg" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>
      <div id="success-msg" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-600"></div>

      <form id="product-form" class="space-y-5">
        <div class="card p-5 space-y-4">
          <h3 class="font-medium text-gray-700 border-b border-gray-100 pb-2">基本信息</h3>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">商品名称 <span class="text-red-500">*</span></label>
            <input type="text" id="prod-name" class="input-field" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">商品 Slug <span class="text-red-500">*</span></label>
            <input type="text" id="prod-slug" class="input-field font-mono" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">商品分类</label>
            <select id="prod-category" class="input-field">
              <option value="">请选择分类</option>
            </select>
          </div>
        </div>

        <div class="card p-5 space-y-4">
          <h3 class="font-medium text-gray-700 border-b border-gray-100 pb-2">价格与库存</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">售价（元）<span class="text-red-500">*</span></label>
              <input type="number" id="prod-price" class="input-field" step="0.01" min="0" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">原价（元）</label>
              <input type="number" id="prod-original-price" class="input-field" step="0.01" min="0" placeholder="选填" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">库存数量 <span class="text-red-500">*</span></label>
              <input type="number" id="prod-stock" class="input-field" min="0" />
            </div>
          </div>
        </div>

        <div class="card p-5 space-y-4">
          <h3 class="font-medium text-gray-700 border-b border-gray-100 pb-2">商品图片</h3>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">主图 URL</label>
            <input type="url" id="prod-main-image" class="input-field" placeholder="https://..." />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">图片列表（每行一个URL）</label>
            <textarea id="prod-images" class="input-field" rows="4"></textarea>
          </div>
        </div>

        <div class="card p-5 space-y-4">
          <h3 class="font-medium text-gray-700 border-b border-gray-100 pb-2">商品描述</h3>
          <textarea id="prod-description" class="input-field" rows="6"></textarea>
        </div>

        <div class="card p-5 space-y-4">
          <h3 class="font-medium text-gray-700 border-b border-gray-100 pb-2">发布设置</h3>
          <select id="prod-status" class="input-field max-w-xs">
            <option value="active">上架</option>
            <option value="inactive">下架</option>
          </select>
        </div>

        <div class="flex gap-3">
          <button type="submit" id="submit-btn" class="btn-primary px-8">保存修改</button>
          <a href="/admin/products/" class="btn-outline px-8">取消</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ id }}>
  async function loadProduct() {
    try {
      const [productRes, categoriesRes] = await Promise.all([
        fetch(`/api/admin/products/${id}`, { credentials: 'include' }),
        fetch('/api/admin/categories', { credentials: 'include' })
      ]);

      if (productRes.status === 401) { window.location.href = '/admin/login'; return; }

      const pData = await productRes.json();
      const product = pData.product || pData;

      if (categoriesRes.ok) {
        const cData = await categoriesRes.json();
        const categories = cData.categories || cData || [];
        const select = document.getElementById('prod-category') as HTMLSelectElement;
        categories.forEach((cat: any) => {
          const opt = document.createElement('option');
          opt.value = cat.id;
          opt.textContent = cat.name;
          if (cat.id === product.category_id) opt.selected = true;
          select.appendChild(opt);
        });
      }

      // 填充数据
      (document.getElementById('prod-name') as HTMLInputElement).value = product.name || '';
      (document.getElementById('prod-slug') as HTMLInputElement).value = product.slug || '';
      (document.getElementById('prod-price') as HTMLInputElement).value = product.price || '';
      (document.getElementById('prod-original-price') as HTMLInputElement).value = product.original_price || '';
      (document.getElementById('prod-stock') as HTMLInputElement).value = product.stock || '0';
      (document.getElementById('prod-main-image') as HTMLInputElement).value = product.main_image || '';
      (document.getElementById('prod-images') as HTMLTextAreaElement).value = (product.images || []).join('\n');
      (document.getElementById('prod-description') as HTMLTextAreaElement).value = product.description || '';
      (document.getElementById('prod-status') as HTMLSelectElement).value = product.status || (product.is_active ? 'active' : 'inactive');

      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('form-container')!.classList.remove('hidden');
    } catch (e) {
      window.location.href = '/admin/products/';
    }
  }

  document.getElementById('product-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errorEl = document.getElementById('error-msg')!;
    const successEl = document.getElementById('success-msg')!;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    const name = (document.getElementById('prod-name') as HTMLInputElement).value.trim();
    const slug = (document.getElementById('prod-slug') as HTMLInputElement).value.trim();
    const price = parseFloat((document.getElementById('prod-price') as HTMLInputElement).value);
    const stock = parseInt((document.getElementById('prod-stock') as HTMLInputElement).value);
    const originalPrice = parseFloat((document.getElementById('prod-original-price') as HTMLInputElement).value) || null;
    const categoryId = (document.getElementById('prod-category') as HTMLSelectElement).value;
    const mainImage = (document.getElementById('prod-main-image') as HTMLInputElement).value.trim();
    const imagesText = (document.getElementById('prod-images') as HTMLTextAreaElement).value.trim();
    const description = (document.getElementById('prod-description') as HTMLTextAreaElement).value.trim();
    const status = (document.getElementById('prod-status') as HTMLSelectElement).value;

    if (!name || !slug || isNaN(price) || isNaN(stock)) {
      errorEl.textContent = '请填写必填项';
      errorEl.classList.remove('hidden');
      return;
    }

    const images = imagesText ? imagesText.split('\n').map((s: string) => s.trim()).filter(Boolean) : [];
    if (mainImage && !images.includes(mainImage)) images.unshift(mainImage);

    btn.disabled = true;
    btn.textContent = '保存中...';

    try {
      const res = await fetch(`/api/admin/products/${id}`, {
        method: 'PUT', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name, slug, price, stock, original_price: originalPrice,
          category_id: categoryId ? parseInt(categoryId) : null,
          main_image: mainImage || images[0] || null, images, description, status
        })
      });

      if (res.ok) {
        successEl.textContent = '保存成功！';
        successEl.classList.remove('hidden');
        setTimeout(() => window.location.href = '/admin/products/', 1000);
      } else {
        const d = await res.json().catch(() => ({}));
        errorEl.textContent = d.message || '保存失败';
        errorEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = '保存修改';
      }
    } catch {
      errorEl.textContent = '网络错误';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = '保存修改';
    }
  });

  loadProduct();
</script>
