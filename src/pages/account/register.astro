---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="注册">
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 justify-center">
          <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-6 h-6 text-white fill-current">
              <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 2-8 2 2-2 2-4 2-4-5 0-9 4-9 10a9.09 9.09 0 00.1 1.42C2.82 14.49 3 12 3 12 2 17 3.5 19 3.5 19" />
            </svg>
          </div>
          <span class="text-xl font-bold text-primary">绿巢生活館</span>
        </a>
        <h1 class="mt-4 text-2xl font-bold text-gray-900">创建账户</h1>
        <p class="mt-1 text-sm text-gray-500">加入绿巢，享受自然好物</p>
      </div>

      <!-- 注册成功提示 -->
      <div id="register-success" class="hidden">
        <div class="card p-8 text-center">
          <div class="w-16 h-16 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-gray-800 mb-2">注册成功！</h2>
          <p class="text-sm text-gray-500 mb-4">请查收激活邮件，点击邮件中的链接完成账户激活</p>
          <div id="demo-activate-link" class="hidden mb-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
            <p class="text-xs text-yellow-700 mb-2">【演示模式】激活链接：</p>
            <a id="activate-url" href="#" class="text-xs text-primary break-all hover:underline"></a>
          </div>
          <a href="/account/login" class="btn-primary">去登录</a>
        </div>
      </div>

      <!-- 注册表单 -->
      <div id="register-form-container" class="card p-8">
        <div id="error-msg" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>

        <form id="register-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">用户名 <span class="text-red-500">*</span></label>
            <input type="text" id="reg-username" class="input-field" placeholder="4-20位字母、数字或下划线" minlength="4" maxlength="20" required />
            <p class="text-xs text-gray-400 mt-1">用于登录，注册后不可修改</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">邮箱地址 <span class="text-red-500">*</span></label>
            <input type="email" id="reg-email" class="input-field" placeholder="example@email.com" required />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">手机号码</label>
            <input type="tel" id="reg-phone" class="input-field" placeholder="11位手机号（选填）" maxlength="11" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">密码 <span class="text-red-500">*</span></label>
            <div class="relative">
              <input type="password" id="reg-password" class="input-field pr-10" placeholder="至少8位，包含字母和数字" minlength="8" required />
              <button type="button" id="toggle-pwd" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
            <!-- 密码强度 -->
            <div class="flex gap-1 mt-1.5">
              <div class="h-1 flex-1 rounded-full bg-gray-200" id="pwd-strength-1"></div>
              <div class="h-1 flex-1 rounded-full bg-gray-200" id="pwd-strength-2"></div>
              <div class="h-1 flex-1 rounded-full bg-gray-200" id="pwd-strength-3"></div>
              <div class="h-1 flex-1 rounded-full bg-gray-200" id="pwd-strength-4"></div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">确认密码 <span class="text-red-500">*</span></label>
            <input type="password" id="reg-confirm-password" class="input-field" placeholder="再次输入密码" required />
          </div>

          <div class="flex items-start gap-2 pt-1">
            <input type="checkbox" id="agree-terms" class="w-4 h-4 accent-primary mt-0.5 cursor-pointer" required />
            <label for="agree-terms" class="text-sm text-gray-600 cursor-pointer">
              我已阅读并同意
              <span class="text-primary">用户服务协议</span>
              和
              <span class="text-primary">隐私政策</span>
            </label>
          </div>

          <button type="submit" id="register-btn" class="btn-primary w-full py-3 text-base">
            注册账户
          </button>
        </form>

        <div class="mt-6 text-center text-sm text-gray-500">
          已有账户？<a href="/account/login" class="text-primary hover:text-primary-dark font-medium transition-colors">立即登录</a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  // 密码显示/隐藏
  document.getElementById('toggle-pwd')?.addEventListener('click', () => {
    const input = document.getElementById('reg-password') as HTMLInputElement;
    input.type = input.type === 'password' ? 'text' : 'password';
  });

  // 密码强度
  document.getElementById('reg-password')?.addEventListener('input', (e) => {
    const pwd = (e.target as HTMLInputElement).value;
    let strength = 0;
    if (pwd.length >= 8) strength++;
    if (/[a-z]/.test(pwd) && /[A-Z]/.test(pwd)) strength++;
    else if (/[a-zA-Z]/.test(pwd)) strength++;
    if (/\d/.test(pwd)) strength++;
    if (/[!@#$%^&*]/.test(pwd)) strength++;

    const colors = ['', 'bg-red-400', 'bg-yellow-400', 'bg-blue-400', 'bg-primary'];
    for (let i = 1; i <= 4; i++) {
      const bar = document.getElementById(`pwd-strength-${i}`)!;
      bar.className = `h-1 flex-1 rounded-full ${i <= strength ? colors[Math.min(strength, 4)] : 'bg-gray-200'}`;
    }
  });

  document.getElementById('register-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('reg-username') as HTMLInputElement).value.trim();
    const email = (document.getElementById('reg-email') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('reg-phone') as HTMLInputElement).value.trim();
    const password = (document.getElementById('reg-password') as HTMLInputElement).value;
    const confirmPwd = (document.getElementById('reg-confirm-password') as HTMLInputElement).value;
    const errorEl = document.getElementById('error-msg')!;
    const btn = document.getElementById('register-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');

    if (password !== confirmPwd) {
      errorEl.textContent = '两次输入的密码不一致';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = '注册中...';

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, email, password, phone: phone || undefined })
      });

      const data = await res.json();

      if (res.ok) {
        document.getElementById('register-form-container')!.classList.add('hidden');
        document.getElementById('register-success')!.classList.remove('hidden');

        // 演示模式：显示激活链接
        if (data.activate_url || data.token) {
          const token = data.token || '';
          const activateUrl = data.activate_url || `${window.location.origin}/account/activate?token=${token}`;
          const linkEl = document.getElementById('activate-url') as HTMLAnchorElement;
          linkEl.href = activateUrl;
          linkEl.textContent = activateUrl;
          document.getElementById('demo-activate-link')!.classList.remove('hidden');
        }
      } else {
        errorEl.textContent = data.message || '注册失败，请重试';
        errorEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = '注册账户';
      }
    } catch (err) {
      errorEl.textContent = '网络错误，请重试';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = '注册账户';
    }
  });
</script>
