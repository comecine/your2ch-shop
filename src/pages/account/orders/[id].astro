---
import MainLayout from '../../../layouts/MainLayout.astro';

const { id } = Astro.params;
---

<MainLayout title="订单详情">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 成功提示 -->
    <div id="success-banner" class="hidden mb-5 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      <div>
        <div class="font-medium text-green-800">订单提交成功！</div>
        <div class="text-sm text-green-600">请按照银行转账信息完成付款，转账后发送凭证到 service@your2ch.com</div>
      </div>
    </div>

    <div class="flex items-center gap-3 mb-6">
      <a href="/account/orders" class="text-gray-400 hover:text-gray-600 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">订单详情</h1>
    </div>

    <div id="order-loading" class="flex justify-center py-16">
      <svg class="w-8 h-8 animate-spin text-primary" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
      </svg>
    </div>

    <div id="order-content" class="hidden space-y-5"></div>
  </div>
</MainLayout>

<script define:vars={{ id }}>
  const statusSteps = [
    { key: 'pending', label: '已下单', icon: '📝' },
    { key: 'confirmed', label: '已确认', icon: '✅' },
    { key: 'shipped', label: '已发货', icon: '🚚' },
    { key: 'completed', label: '已完成', icon: '🎉' },
  ];

  const statusMap: Record<string, string> = {
    pending: '待确认',
    confirmed: '已确认',
    shipped: '已发货',
    completed: '已完成',
    cancelled: '已取消',
  };

  async function loadOrder() {
    // 检查是否是新订单
    if (new URLSearchParams(window.location.search).get('success') === '1') {
      document.getElementById('success-banner')!.classList.remove('hidden');
    }

    try {
      const res = await fetch('/api/auth/me', { credentials: 'include' });
      if (!res.ok) { window.location.href = '/account/login?redirect=/account/orders'; return; }

      const orderRes = await fetch(`/api/orders/${id}`, { credentials: 'include' });
      if (!orderRes.ok) { window.location.href = '/account/orders'; return; }

      const data = await orderRes.json();
      const order = data.order || data;
      const items = order.items || [];

      document.getElementById('order-loading')!.classList.add('hidden');
      const content = document.getElementById('order-content')!;
      content.classList.remove('hidden');

      const isCancelled = order.status === 'cancelled';
      const currentStepIndex = statusSteps.findIndex(s => s.key === order.status);

      content.innerHTML = `
        <!-- 状态时间线 -->
        ${!isCancelled ? `
        <div class="card p-5">
          <h2 class="font-semibold text-gray-800 mb-5">订单状态</h2>
          <div class="flex items-center">
            ${statusSteps.map((step, index) => `
              <div class="flex-1 flex flex-col items-center ${index < statusSteps.length - 1 ? 'relative' : ''}">
                ${index < statusSteps.length - 1 ? `
                  <div class="absolute top-5 left-1/2 w-full h-0.5 ${index < currentStepIndex ? 'bg-primary' : 'bg-gray-200'}" style="transform: translateX(50%);"></div>
                ` : ''}
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg z-10 mb-2 ${index <= currentStepIndex ? 'bg-primary text-white' : 'bg-gray-100 text-gray-400'}">
                  ${step.icon}
                </div>
                <div class="text-xs text-center ${index <= currentStepIndex ? 'text-primary font-medium' : 'text-gray-400'}">${step.label}</div>
              </div>
            `).join('')}
          </div>
        </div>
        ` : `
        <div class="card p-5 border-red-200 bg-red-50">
          <div class="flex items-center gap-3 text-red-600">
            <span class="text-2xl">❌</span>
            <div>
              <div class="font-medium">订单已取消</div>
              ${order.cancelled_reason ? `<div class="text-sm opacity-80">${order.cancelled_reason}</div>` : ''}
            </div>
          </div>
        </div>
        `}

        <!-- 订单信息 -->
        <div class="card p-5">
          <h2 class="font-semibold text-gray-800 mb-4">订单信息</h2>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="text-gray-500">订单号：</span><span class="font-mono text-gray-800">${order.order_no || order.id}</span></div>
            <div><span class="text-gray-500">下单时间：</span><span class="text-gray-800">${new Date(order.created_at).toLocaleString('zh-CN')}</span></div>
            <div><span class="text-gray-500">订单状态：</span><span class="font-medium text-gray-800">${statusMap[order.status] || order.status}</span></div>
            <div><span class="text-gray-500">支付方式：</span><span class="text-gray-800">银行转账</span></div>
            ${order.remark ? `<div class="col-span-2"><span class="text-gray-500">备注：</span><span class="text-gray-800">${order.remark}</span></div>` : ''}
          </div>
        </div>

        <!-- 收货地址 -->
        ${order.address ? `
        <div class="card p-5">
          <h2 class="font-semibold text-gray-800 mb-3">收货地址</h2>
          <div class="text-sm text-gray-700">
            <div class="flex items-center gap-3 mb-1">
              <span class="font-medium">${order.address.name}</span>
              <span>${order.address.phone}</span>
            </div>
            <div class="text-gray-500">${order.address.province || ''}${order.address.city || ''}${order.address.district || ''} ${order.address.detail || ''}</div>
          </div>
        </div>
        ` : ''}

        <!-- 商品明细 -->
        <div class="card p-5">
          <h2 class="font-semibold text-gray-800 mb-4">商品明细</h2>
          <div class="space-y-3">
            ${items.map((item: any) => `
              <div class="flex items-center gap-3">
                <img src="${item.product_image || 'https://placehold.co/60x60/dcfce7/16a34a?text=图'}"
                  alt="${item.product_name}"
                  class="w-16 h-16 rounded-lg object-cover flex-shrink-0"
                  onerror="this.src='https://placehold.co/60x60/dcfce7/16a34a?text=图'"
                />
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-gray-800 line-clamp-2">${item.product_name}</div>
                  <div class="text-xs text-gray-400 mt-0.5">单价 ¥${parseFloat(item.price).toFixed(2)} × ${item.quantity}</div>
                </div>
                <div class="text-sm font-bold text-gray-800 flex-shrink-0">¥${(parseFloat(item.price) * item.quantity).toFixed(2)}</div>
              </div>
            `).join('')}
          </div>

          <!-- 价格汇总 -->
          <div class="mt-4 pt-4 border-t border-gray-100 space-y-2">
            <div class="flex justify-between text-sm text-gray-500">
              <span>商品总额</span>
              <span>¥${(parseFloat(order.total_amount) - (parseFloat(order.shipping_fee) || 0)).toFixed(2)}</span>
            </div>
            <div class="flex justify-between text-sm text-gray-500">
              <span>运费</span>
              <span>${parseFloat(order.shipping_fee || 0) === 0 ? '免运费' : '¥' + parseFloat(order.shipping_fee).toFixed(2)}</span>
            </div>
            <div class="flex justify-between font-bold text-base pt-2 border-t border-gray-100">
              <span>实付金额</span>
              <span class="text-red-500">¥${parseFloat(order.total_amount).toFixed(2)}</span>
            </div>
          </div>
        </div>

        <!-- 支付信息（待确认状态显示） -->
        ${order.status === 'pending' ? `
        <div class="card p-5 border-primary bg-primary-light">
          <h2 class="font-semibold text-primary mb-3">支付信息</h2>
          <div class="text-sm text-gray-700 space-y-1.5">
            <div>开户行：中国工商银行</div>
            <div>账户名：江西远南贸易有限公司</div>
            <div>账号：<span class="font-mono font-bold text-gray-900">1234 5678 9012 3456</span></div>
            <div>转账金额：<span class="font-bold text-red-500">¥${parseFloat(order.total_amount).toFixed(2)}</span></div>
            <div class="text-xs text-gray-500 mt-2">转账备注请填写订单号 <strong>${order.order_no || order.id}</strong>，并将凭证发送到 service@your2ch.com</div>
          </div>
        </div>
        ` : ''}
      `;
    } catch (e) {
      document.getElementById('order-loading')!.innerHTML = '<div class="text-center py-16 text-gray-400">加载失败，请刷新重试</div>';
    }
  }

  loadOrder();
</script>
