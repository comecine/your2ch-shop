---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="首页">
  <!-- Hero Banner 轮播 -->
  <section class="relative bg-gray-900 overflow-hidden" style="min-height: 400px;">
    <div id="banner-container" class="relative w-full" style="height: 400px;">
      <!-- 默认 Banner（加载中） -->
      <div id="banner-loading" class="absolute inset-0 flex items-center justify-center bg-gradient-to-r from-green-800 to-green-600">
        <div class="text-center text-white">
          <div class="text-4xl font-bold mb-2">绿巢生活館</div>
          <div class="text-xl opacity-80">自然好物 · 呵护家庭</div>
          <div class="mt-6">
            <a href="/products" class="inline-block bg-white text-primary font-medium px-8 py-3 rounded-full hover:bg-primary-light transition-colors">
              立即选购
            </a>
          </div>
        </div>
      </div>
      <!-- 轮播内容由 JS 插入 -->
      <div id="banner-slides" class="hidden relative w-full h-full"></div>
    </div>

    <!-- 轮播指示点 -->
    <div id="banner-dots" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10"></div>

    <!-- 轮播箭头 -->
    <button id="banner-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/30 hover:bg-black/50 text-white rounded-full flex items-center justify-center transition-colors hidden">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button id="banner-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/30 hover:bg-black/50 text-white rounded-full flex items-center justify-center transition-colors hidden">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </section>

  <!-- 分类快捷入口 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div id="category-icons" class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-8 gap-4">
      <!-- 骨架屏 -->
      {Array(8).fill(0).map(() => (
        <div class="animate-pulse flex flex-col items-center gap-2">
          <div class="w-14 h-14 bg-gray-200 rounded-xl"></div>
          <div class="h-3 w-12 bg-gray-200 rounded"></div>
        </div>
      ))}
    </div>
  </section>

  <!-- 热销商品 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <div class="w-1 h-7 bg-primary rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-800">热销好物</h2>
        <span class="text-sm text-gray-400">大家都在买</span>
      </div>
      <a href="/products?sort=sales" class="text-sm text-primary hover:text-primary-dark transition-colors flex items-center gap-1">
        查看更多
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div id="hot-products" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array(8).fill(0).map(() => (
        <div class="card animate-pulse">
          <div class="bg-gray-200 aspect-square"></div>
          <div class="p-3 space-y-2">
            <div class="h-4 bg-gray-200 rounded"></div>
            <div class="h-4 bg-gray-200 rounded w-2/3"></div>
            <div class="h-5 bg-gray-200 rounded w-1/3"></div>
            <div class="h-8 bg-gray-200 rounded"></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 活动 Banner（静态） -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="rounded-xl overflow-hidden bg-gradient-to-r from-green-500 to-green-400 p-6 flex items-center justify-between text-white">
        <div>
          <div class="text-xl font-bold mb-1">满99元包邮</div>
          <div class="text-sm opacity-80">全场商品免运费，放心选购</div>
          <a href="/products" class="mt-3 inline-block text-sm border border-white px-4 py-1.5 rounded-full hover:bg-white hover:text-primary transition-colors">
            立即选购
          </a>
        </div>
        <div class="text-6xl opacity-20">🚚</div>
      </div>
      <div class="rounded-xl overflow-hidden bg-gradient-to-r from-amber-500 to-orange-400 p-6 flex items-center justify-between text-white">
        <div>
          <div class="text-xl font-bold mb-1">新人专享优惠</div>
          <div class="text-sm opacity-80">注册即可享受首单9折</div>
          <a href="/account/register" class="mt-3 inline-block text-sm border border-white px-4 py-1.5 rounded-full hover:bg-white hover:text-amber-500 transition-colors">
            立即注册
          </a>
        </div>
        <div class="text-6xl opacity-20">🎁</div>
      </div>
    </div>
  </section>

  <!-- 新品上市 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <div class="w-1 h-7 bg-amber-400 rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-800">新品上市</h2>
        <span class="text-sm text-gray-400">最新到货</span>
      </div>
      <a href="/products?sort=newest" class="text-sm text-primary hover:text-primary-dark transition-colors flex items-center gap-1">
        查看更多
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div id="new-products" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array(8).fill(0).map(() => (
        <div class="card animate-pulse">
          <div class="bg-gray-200 aspect-square"></div>
          <div class="p-3 space-y-2">
            <div class="h-4 bg-gray-200 rounded"></div>
            <div class="h-4 bg-gray-200 rounded w-2/3"></div>
            <div class="h-5 bg-gray-200 rounded w-1/3"></div>
            <div class="h-8 bg-gray-200 rounded"></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 品牌优势 -->
  <section class="bg-primary-light py-12 mt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="flex flex-col items-center gap-2">
          <div class="text-3xl">🌿</div>
          <div class="font-bold text-gray-800">天然环保</div>
          <div class="text-sm text-gray-500">精选天然材质</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="text-3xl">✅</div>
          <div class="font-bold text-gray-800">品质保障</div>
          <div class="text-sm text-gray-500">严格质量把控</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="text-3xl">🚚</div>
          <div class="font-bold text-gray-800">满99包邮</div>
          <div class="text-sm text-gray-500">快速配送到家</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="text-3xl">💬</div>
          <div class="font-bold text-gray-800">贴心客服</div>
          <div class="text-sm text-gray-500">7天售后保障</div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  function renderProductCard(product: any): string {
    return `
      <div class="card group cursor-pointer hover:shadow-md transition-shadow duration-200">
        <a href="/products/${product.slug}" class="block">
          <div class="relative overflow-hidden bg-gray-50 aspect-square">
            <img src="${product.image_url || 'https://placehold.co/400x400/dcfce7/16a34a?text=暂无图片'}"
              alt="${product.name}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              onerror="this.src='https://placehold.co/400x400/dcfce7/16a34a?text=暂无图片'"
            />
            ${product.original_price && product.original_price > product.price ? '<div class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-0.5 rounded-full font-medium">特价</div>' : ''}
            ${product.stock === 0 ? '<div class="absolute inset-0 bg-black/40 flex items-center justify-center"><span class="bg-white text-gray-600 text-sm px-3 py-1 rounded-full font-medium">暂时缺货</span></div>' : ''}
          </div>
          <div class="p-3">
            <h3 class="text-sm text-gray-800 line-clamp-2 mb-2 group-hover:text-primary transition-colors min-h-[2.5rem]">
              ${product.name}
            </h3>
            <div class="flex items-end gap-2 mb-2">
              <span class="text-lg font-bold text-red-500">¥${parseFloat(product.price).toFixed(2)}</span>
              ${product.original_price && product.original_price > product.price ? `<span class="text-xs text-gray-400 line-through">¥${parseFloat(product.original_price).toFixed(2)}</span>` : ''}
            </div>
            ${product.sales > 0 ? `<div class="text-xs text-gray-400">已售 ${product.sales}</div>` : ''}
          </div>
        </a>
        <div class="px-3 pb-3">
          <button
            class="add-to-cart-btn w-full py-2 text-sm font-medium text-primary border border-primary rounded-lg hover:bg-primary hover:text-white transition-colors ${product.stock === 0 ? 'opacity-50 cursor-not-allowed' : ''}"
            data-product-id="${product.id}"
            ${product.stock === 0 ? 'disabled' : ''}
          >
            ${product.stock === 0 ? '暂时缺货' : '加入购物车'}
          </button>
        </div>
      </div>
    `;
  }

  // 加载 Banner
  async function loadBanners() {
    try {
      const res = await fetch('/api/banners', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const banners = data.banners || data || [];
      if (!banners.length) return;

      const container = document.getElementById('banner-slides');
      const loading = document.getElementById('banner-loading');
      const dotsContainer = document.getElementById('banner-dots');
      const prevBtn = document.getElementById('banner-prev');
      const nextBtn = document.getElementById('banner-next');
      if (!container || !loading) return;

      loading.classList.add('hidden');
      container.classList.remove('hidden');

      banners.forEach((banner: any, i: number) => {
        const slide = document.createElement('div');
        slide.className = `absolute inset-0 transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`;
        slide.dataset.index = String(i);
        slide.innerHTML = `
          <a href="${banner.link_url || '/products'}" class="block w-full h-full">
            <img src="${banner.image_url}" alt="${banner.title || ''}"
              class="w-full h-full object-cover"
              onerror="this.parentElement.parentElement.style.background='linear-gradient(to right, #15803d, #16a34a)'"
            />
            ${banner.title ? `
              <div class="absolute inset-0 bg-gradient-to-r from-black/40 to-transparent flex items-center px-12">
                <div class="text-white">
                  <h2 class="text-3xl md:text-4xl font-bold mb-2">${banner.title}</h2>
                  ${banner.subtitle ? `<p class="text-lg opacity-80">${banner.subtitle}</p>` : ''}
                </div>
              </div>
            ` : ''}
          </a>
        `;
        container.appendChild(slide);

        if (dotsContainer) {
          const dot = document.createElement('button');
          dot.className = `w-2 h-2 rounded-full transition-all ${i === 0 ? 'bg-white w-6' : 'bg-white/50'}`;
          dot.addEventListener('click', () => goToSlide(i));
          dotsContainer.appendChild(dot);
        }
      });

      if (banners.length > 1) {
        prevBtn?.classList.remove('hidden');
        nextBtn?.classList.remove('hidden');
      }

      let current = 0;
      function goToSlide(index: number) {
        const slides = container!.querySelectorAll('[data-index]');
        const dots = dotsContainer?.querySelectorAll('button') || [];
        slides[current].classList.replace('opacity-100', 'opacity-0');
        dots[current]?.classList.remove('w-6');
        dots[current]?.classList.add('bg-white/50');
        dots[current]?.classList.remove('bg-white');
        current = (index + banners.length) % banners.length;
        slides[current].classList.replace('opacity-0', 'opacity-100');
        dots[current]?.classList.add('w-6', 'bg-white');
        dots[current]?.classList.remove('bg-white/50');
      }

      prevBtn?.addEventListener('click', () => goToSlide(current - 1));
      nextBtn?.addEventListener('click', () => goToSlide(current + 1));

      const autoPlay = setInterval(() => goToSlide(current + 1), 4000);
      container.addEventListener('mouseenter', () => clearInterval(autoPlay));
    } catch (e) {}
  }

  // 加载分类图标
  async function loadCategoryIcons() {
    try {
      const res = await fetch('/api/categories', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const categories = data.categories || data || [];
      const container = document.getElementById('category-icons');
      if (!container || !categories.length) return;

      container.innerHTML = categories.slice(0, 8).map((cat: any) => `
        <a href="/products?category=${cat.slug}" class="flex flex-col items-center gap-2 group">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center text-2xl group-hover:bg-primary group-hover:text-white transition-colors">
            ${cat.icon || '🛍️'}
          </div>
          <span class="text-xs text-gray-600 group-hover:text-primary transition-colors text-center">${cat.name}</span>
        </a>
      `).join('');
    } catch (e) {}
  }

  // 加载商品列表
  async function loadProducts(containerId: string, queryStr: string) {
    try {
      const res = await fetch(`/api/products?${queryStr}`, { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const products = data.data?.products || [];
      const container = document.getElementById(containerId);
      if (!container) return;

      if (!products.length) {
        container.innerHTML = '<div class="col-span-4 text-center text-gray-400 py-8">暂无商品</div>';
        return;
      }

      container.innerHTML = products.slice(0, 8).map((p: any) => renderProductCard(p)).join('');

      // 绑定加入购物车
      container.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          const button = e.currentTarget as HTMLButtonElement;
          const productId = button.dataset.productId;
          if (!productId) return;

          const originalText = button.textContent?.trim();
          button.disabled = true;
          button.textContent = '添加中...';

          try {
            const res = await fetch('/api/cart', {
              method: 'POST',
              credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ product_id: parseInt(productId), quantity: 1 })
            });

            if (res.status === 401) {
              window.location.href = '/account/login?redirect=/';
              return;
            }

            if (res.ok) {
              button.textContent = '已加入';
              const cartCount = parseInt(localStorage.getItem('cartCount') || '0') + 1;
              localStorage.setItem('cartCount', String(cartCount));
              window.dispatchEvent(new StorageEvent('storage', { key: 'cartCount', newValue: String(cartCount) }));
              const badge = document.getElementById('cart-badge');
              if (badge) {
                badge.textContent = cartCount > 99 ? '99+' : String(cartCount);
                badge.classList.remove('hidden');
              }
              setTimeout(() => {
                button.textContent = originalText || '加入购物车';
                button.disabled = false;
              }, 1500);
            } else {
              button.textContent = '失败，重试';
              setTimeout(() => {
                button.textContent = originalText || '加入购物车';
                button.disabled = false;
              }, 2000);
            }
          } catch (err) {
            button.textContent = originalText || '加入购物车';
            button.disabled = false;
          }
        });
      });
    } catch (e) {}
  }

  // 并行加载
  loadBanners();
  loadCategoryIcons();
  loadProducts('hot-products', 'sort=sales&limit=8');
  loadProducts('new-products', 'sort=newest&limit=8');
</script>
