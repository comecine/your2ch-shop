---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="首页">
  <!-- Hero Banner 轮播 -->
  <section class="relative bg-gray-900 overflow-hidden" style="min-height: 460px;">
    <div id="banner-container" class="relative w-full" style="height: 460px;">
      <div id="banner-loading" class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-green-900 via-green-800 to-emerald-700">
        <div class="text-center text-white">
          <div class="text-5xl font-bold mb-3 tracking-tight">绿巢生活館</div>
          <div class="text-xl opacity-75 font-light">自然好物 · 呵护每个家庭</div>
          <div class="mt-8">
            <a href="/products" class="inline-block bg-white text-primary font-semibold px-10 py-3.5 rounded-full hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-sm">
              立即选购 →
            </a>
          </div>
        </div>
      </div>
      <div id="banner-slides" class="hidden relative w-full h-full"></div>
    </div>
    <div id="banner-dots" class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-10"></div>
    <button id="banner-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/25 backdrop-blur-sm hover:bg-black/45 text-white rounded-full flex items-center justify-center transition-all hidden">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="banner-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/25 backdrop-blur-sm hover:bg-black/45 text-white rounded-full flex items-center justify-center transition-all hidden">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </button>
  </section>

  <!-- 品牌优势（紧接 Banner） -->
  <section class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
        <!-- 天然环保 -->
        <div class="flex items-center gap-3 py-5 px-6 group hover:bg-green-50/50 transition-colors">
          <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center flex-shrink-0 group-hover:bg-primary-light transition-colors">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-1.2 5.4-5 7-5 11a5 5 0 0010 0c0-4-3.8-5.6-5-11z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14c0-2 1.5-3.5 3-4"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-800">天然环保</div>
            <div class="text-xs text-gray-400 mt-0.5">精选天然材质</div>
          </div>
        </div>
        <!-- 品质保障 -->
        <div class="flex items-center gap-3 py-5 px-6 group hover:bg-green-50/50 transition-colors">
          <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-100 transition-colors">
            <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-800">品质保障</div>
            <div class="text-xs text-gray-400 mt-0.5">严格质量把控</div>
          </div>
        </div>
        <!-- 满99包邮 -->
        <div class="flex items-center gap-3 py-5 px-6 group hover:bg-green-50/50 transition-colors">
          <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center flex-shrink-0 group-hover:bg-orange-100 transition-colors">
            <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-800">满99包邮</div>
            <div class="text-xs text-gray-400 mt-0.5">快速配送到家</div>
          </div>
        </div>
        <!-- 7天售后 -->
        <div class="flex items-center gap-3 py-5 px-6 group hover:bg-green-50/50 transition-colors">
          <div class="w-10 h-10 rounded-full bg-purple-50 flex items-center justify-center flex-shrink-0 group-hover:bg-purple-100 transition-colors">
            <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-800">贴心客服</div>
            <div class="text-xs text-gray-400 mt-0.5">7天售后保障</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 分类快捷入口 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div id="category-icons" class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-8 gap-3">
      {Array(8).fill(0).map(() => (
        <div class="animate-pulse flex flex-col items-center gap-2">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl"></div>
          <div class="h-3 w-12 bg-gray-100 rounded-full"></div>
        </div>
      ))}
    </div>
  </section>

  <!-- 热销商品 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex items-center justify-between mb-6">
      <div class="section-header mb-0">
        <div class="section-header-bar bg-primary"></div>
        <div>
          <h2 class="text-xl font-bold text-gray-800 leading-none">热销好物</h2>
          <p class="text-xs text-gray-400 mt-1">大家都在买</p>
        </div>
      </div>
      <a href="/products?sort=sales" class="text-sm text-primary hover:text-primary-dark transition-colors flex items-center gap-1 font-medium">
        查看更多
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div id="hot-products" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array(8).fill(0).map(() => (
        <div class="product-card animate-pulse">
          <div class="bg-gray-100 aspect-square"></div>
          <div class="p-3 space-y-2">
            <div class="h-3.5 bg-gray-100 rounded-full"></div>
            <div class="h-3.5 bg-gray-100 rounded-full w-3/4"></div>
            <div class="h-4 bg-gray-100 rounded-full w-1/3 mt-3"></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 活动 Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="relative rounded-2xl overflow-hidden bg-gradient-to-r from-emerald-600 to-green-500 p-6 text-white">
        <div class="relative z-10">
          <div class="text-xl font-bold mb-1">满99元包邮</div>
          <div class="text-sm opacity-80 mb-4">全场商品免运费，放心选购</div>
          <a href="/products" class="inline-block text-sm border border-white/70 px-5 py-2 rounded-full hover:bg-white hover:text-primary transition-all duration-200 font-medium">
            立即选购
          </a>
        </div>
        <div class="absolute right-0 top-0 h-full w-32 opacity-10">
          <svg viewBox="0 0 100 100" class="h-full" fill="white">
            <circle cx="80" cy="20" r="40"/>
            <circle cx="20" cy="80" r="25"/>
          </svg>
        </div>
      </div>
      <div class="relative rounded-2xl overflow-hidden bg-gradient-to-r from-amber-500 to-orange-400 p-6 text-white">
        <div class="relative z-10">
          <div class="text-xl font-bold mb-1">新人专享优惠</div>
          <div class="text-sm opacity-80 mb-4">注册即可享受首单9折</div>
          <a href="/account/register" class="inline-block text-sm border border-white/70 px-5 py-2 rounded-full hover:bg-white hover:text-amber-500 transition-all duration-200 font-medium">
            立即注册
          </a>
        </div>
        <div class="absolute right-0 top-0 h-full w-32 opacity-10">
          <svg viewBox="0 0 100 100" class="h-full" fill="white">
            <circle cx="70" cy="30" r="35"/>
            <circle cx="30" cy="75" r="20"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- 新品上市 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-12">
    <div class="flex items-center justify-between mb-6">
      <div class="section-header mb-0">
        <div class="section-header-bar bg-amber-400"></div>
        <div>
          <h2 class="text-xl font-bold text-gray-800 leading-none">新品上市</h2>
          <p class="text-xs text-gray-400 mt-1">最新到货</p>
        </div>
      </div>
      <a href="/products?sort=newest" class="text-sm text-primary hover:text-primary-dark transition-colors flex items-center gap-1 font-medium">
        查看更多
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div id="new-products" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array(8).fill(0).map(() => (
        <div class="product-card animate-pulse">
          <div class="bg-gray-100 aspect-square"></div>
          <div class="p-3 space-y-2">
            <div class="h-3.5 bg-gray-100 rounded-full"></div>
            <div class="h-3.5 bg-gray-100 rounded-full w-3/4"></div>
            <div class="h-4 bg-gray-100 rounded-full w-1/3 mt-3"></div>
          </div>
        </div>
      ))}
    </div>
  </section>
</MainLayout>

<script>
  function renderStars(sales: number): string {
    const score = sales > 500 ? 5 : sales > 100 ? 4 : sales > 20 ? 3 : 4;
    const count = Math.max(10, Math.min(sales, 999));
    const stars = '★'.repeat(score) + '☆'.repeat(5 - score);
    return `<div class="flex items-center gap-1 mb-2">
      <span class="text-amber-400 text-xs tracking-tight">${stars}</span>
      <span class="text-xs text-gray-300">(${count})</span>
    </div>`;
  }

  function renderProductCard(product: any): string {
    const imgSrc = product.image_url || 'https://placehold.co/400x400/f0fdf4/16a34a?text=暂无图片';
    const isOnSale = product.original_price && parseFloat(product.original_price) > parseFloat(product.price);
    const outOfStock = product.stock === 0;
    const discount = isOnSale ? Math.round((1 - product.price / product.original_price) * 10) : 0;

    return `
      <div class="product-card group">
        <a href="/products/${product.slug}" class="block">
          <div class="relative overflow-hidden bg-gray-50" style="aspect-ratio:1">
            <img
              src="${imgSrc}"
              alt="${product.name}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.src='https://placehold.co/400x400/f0fdf4/16a34a?text=暂无图片'"
            />
            ${isOnSale ? `<div class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-0.5 rounded-full font-medium shadow-sm">${discount}折</div>` : ''}
            ${outOfStock ? '<div class="absolute inset-0 bg-white/60 flex items-center justify-center"><span class="text-gray-500 text-xs font-medium bg-white px-3 py-1.5 rounded-full shadow-sm">暂时缺货</span></div>' : ''}
          </div>
          <div class="p-3 pb-1">
            <h3 class="text-sm text-gray-700 line-clamp-2 group-hover:text-primary transition-colors leading-snug" style="min-height:2.5rem">
              ${product.name}
            </h3>
            ${renderStars(product.sales || 0)}
            <div class="flex items-baseline gap-1.5 mb-3">
              <span class="text-lg font-bold text-red-500 leading-none">¥${parseFloat(product.price).toFixed(2)}</span>
              ${isOnSale ? `<span class="text-xs text-gray-300 line-through">¥${parseFloat(product.original_price).toFixed(2)}</span>` : ''}
            </div>
          </div>
        </a>
        <div class="px-3 pb-3">
          <button
            class="add-to-cart-btn w-full py-2 text-sm font-medium rounded-lg transition-all duration-200
              ${outOfStock
                ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
                : 'bg-primary-light text-primary hover:bg-primary hover:text-white hover:shadow-md'}"
            data-product-id="${product.id}"
            ${outOfStock ? 'disabled' : ''}
          >
            ${outOfStock ? '暂时缺货' : '加入购物车'}
          </button>
        </div>
      </div>
    `;
  }

  async function loadBanners() {
    try {
      const res = await fetch('/api/banners', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const banners = data.data?.banners || [];
      if (!banners.length) return;

      const container = document.getElementById('banner-slides')!;
      const loading = document.getElementById('banner-loading')!;
      const dotsContainer = document.getElementById('banner-dots')!;
      const prevBtn = document.getElementById('banner-prev')!;
      const nextBtn = document.getElementById('banner-next')!;

      loading.classList.add('hidden');
      container.classList.remove('hidden');

      banners.forEach((banner: any, i: number) => {
        const slide = document.createElement('div');
        slide.className = `absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`;
        slide.dataset.index = String(i);
        slide.innerHTML = `
          <a href="${banner.link_url || '/products'}" class="block w-full h-full">
            <img src="${banner.image_url}" alt="${banner.title || ''}" class="w-full h-full object-cover"
              onerror="this.parentElement.parentElement.style.background='linear-gradient(135deg, #14532d, #16a34a)'"
            />
            ${banner.title ? `
              <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent flex items-center px-10 md:px-16">
                <div class="text-white max-w-md">
                  <h2 class="text-3xl md:text-4xl font-bold mb-2 leading-tight">${banner.title}</h2>
                  ${banner.subtitle ? `<p class="text-base md:text-lg opacity-80 font-light">${banner.subtitle}</p>` : ''}
                </div>
              </div>` : ''}
          </a>`;
        container.appendChild(slide);

        const dot = document.createElement('button');
        dot.className = `transition-all duration-300 rounded-full ${i === 0 ? 'w-6 h-2 bg-white' : 'w-2 h-2 bg-white/40'}`;
        dot.addEventListener('click', () => goToSlide(i));
        dotsContainer.appendChild(dot);
      });

      if (banners.length > 1) { prevBtn.classList.remove('hidden'); nextBtn.classList.remove('hidden'); }

      let current = 0;
      function goToSlide(index: number) {
        const slides = container.querySelectorAll('[data-index]');
        const dots = dotsContainer.querySelectorAll('button');
        slides[current].classList.replace('opacity-100', 'opacity-0');
        dots[current].className = 'w-2 h-2 rounded-full bg-white/40 transition-all duration-300';
        current = (index + banners.length) % banners.length;
        slides[current].classList.replace('opacity-0', 'opacity-100');
        dots[current].className = 'w-6 h-2 rounded-full bg-white transition-all duration-300';
      }

      prevBtn.addEventListener('click', () => goToSlide(current - 1));
      nextBtn.addEventListener('click', () => goToSlide(current + 1));

      let timer = setInterval(() => goToSlide(current + 1), 4500);
      container.addEventListener('mouseenter', () => clearInterval(timer));
      container.addEventListener('mouseleave', () => { timer = setInterval(() => goToSlide(current + 1), 4500); });
    } catch (e) {}
  }

  async function loadCategoryIcons() {
    try {
      const res = await fetch('/api/categories', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const categories = data.data?.categories || [];
      const container = document.getElementById('category-icons');
      if (!container || !categories.length) return;

      container.innerHTML = categories.slice(0, 8).map((cat: any) => `
        <a href="/products?category=${cat.slug}" class="flex flex-col items-center gap-2 group">
          <div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center text-2xl
            group-hover:bg-primary-light group-hover:shadow-md transition-all duration-200 border border-gray-100 group-hover:border-primary/20">
            ${cat.icon || '🛍️'}
          </div>
          <span class="text-xs text-gray-500 group-hover:text-primary transition-colors text-center font-medium">${cat.name}</span>
        </a>
      `).join('');
    } catch (e) {}
  }

  async function loadProducts(containerId: string, queryStr: string) {
    try {
      const res = await fetch(`/api/products?${queryStr}`, { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      const products = data.data?.products || [];
      const container = document.getElementById(containerId);
      if (!container) return;

      if (!products.length) {
        container.innerHTML = '<div class="col-span-4 text-center text-gray-400 py-12">暂无商品</div>';
        return;
      }

      container.innerHTML = products.slice(0, 8).map((p: any) => renderProductCard(p)).join('');

      container.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          const button = e.currentTarget as HTMLButtonElement;
          const productId = button.dataset.productId;
          if (!productId) return;
          const originalText = button.textContent?.trim();
          button.disabled = true;
          button.textContent = '添加中...';
          try {
            const res = await fetch('/api/cart', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ product_id: parseInt(productId), quantity: 1 })
            });
            if (res.status === 401) { window.location.href = '/account/login?redirect=/'; return; }
            if (res.ok) {
              button.textContent = '✓ 已加入';
              button.className = button.className.replace('bg-primary-light text-primary', 'bg-green-500 text-white');
              const count = parseInt(localStorage.getItem('cartCount') || '0') + 1;
              localStorage.setItem('cartCount', String(count));
              window.dispatchEvent(new StorageEvent('storage', { key: 'cartCount', newValue: String(count) }));
              const badge = document.getElementById('cart-badge');
              if (badge) { badge.textContent = count > 99 ? '99+' : String(count); badge.classList.remove('hidden'); }
              setTimeout(() => {
                button.textContent = originalText || '加入购物车';
                button.className = button.className.replace('bg-green-500 text-white', 'bg-primary-light text-primary');
                button.disabled = false;
              }, 1800);
            } else {
              button.textContent = originalText || '加入购物车'; button.disabled = false;
            }
          } catch {
            button.textContent = originalText || '加入购物车'; button.disabled = false;
          }
        });
      });
    } catch (e) {}
  }

  loadBanners();
  loadCategoryIcons();
  loadProducts('hot-products', 'sort=sales&limit=8');
  loadProducts('new-products', 'sort=newest&limit=8');
</script>
